<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>16.0</VCProjectVersion>
    <ProjectGuid>{A1B2C3D4-0005-0005-0005-000000000005}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <ProjectName>GLSnake-Xbox</ProjectName>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Label="Shared" />

  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform" />
  </ImportGroup>

  <PropertyGroup Label="UserMacros" />

  <!-- RXDK_LIBS must be set in your environment, e.g. C:\RXDK\ -->
  <PropertyGroup>
    <XboxSDKDir>$(RXDK_LIBS)</XboxSDKDir>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <OutDir>$(SolutionDir)bin\Debug\Xbox\</OutDir>
    <IntDir>$(SolutionDir)obj\Debug\Xbox\$(ProjectName)\</IntDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <OutDir>$(SolutionDir)bin\Release\Xbox\</OutDir>
    <IntDir>$(SolutionDir)obj\Release\Xbox\$(ProjectName)\</IntDir>
  </PropertyGroup>

  <!-- ================================================================
       DEBUG
       ================================================================ -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <!-- xbox\ first so GL/glut.h, GL/gl.h, sys/timeb.h, windows.h stubs shadow SDK versions -->
      <AdditionalIncludeDirectories>$(ProjectDir)xbox;$(ProjectDir);$(ProjectDir)..\RXGL\RXGL;$(VCToolsInstallDir)include;$(WindowsSdkDir)Include\$(WindowsSdkVersion)ucrt;$(XboxSDKDir)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>_DEBUG;_XBOX;WIN32;HAVE_GLUT;HAVE_FTIME;_CRT_SECURE_NO_DEPRECATE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <BasicRuntimeChecks>Default</BasicRuntimeChecks>
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <EnableEnhancedInstructionSet>StreamingSIMDExtensions</EnableEnhancedInstructionSet>
      <ConformanceMode>false</ConformanceMode>
      <ControlFlowGuard>false</ControlFlowGuard>
      <SupportJustMyCode>false</SupportJustMyCode>
      <WarningLevel>Level3</WarningLevel>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <AdditionalOptions>/std:c++17 /EHs-c- /arch:SSE /FI "$(ProjectDir)xbox\preinclude.h" %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <AdditionalDependencies>xapilibd.lib;d3d8d.lib;d3dx8d.lib;xgraphicsd.lib;xboxkrnl.lib;xbdm.lib;libcmtd.lib</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(XboxSDKDir)lib</AdditionalLibraryDirectories>
      <OutputFile>$(OutDir)GLSnake.exe</OutputFile>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <ProgramDatabaseFile>$(OutDir)GLSnake.pdb</ProgramDatabaseFile>
      <SubSystem>Console</SubSystem>
      <StackReserveSize>4194304</StackReserveSize>
      <TargetMachine>MachineX86</TargetMachine>
      <IgnoreAllDefaultLibraries>true</IgnoreAllDefaultLibraries>
      <ImageHasSafeExceptionHandlers>false</ImageHasSafeExceptionHandlers>
      <AdditionalOptions>/ignore:4254 /FORCE:MULTIPLE %(AdditionalOptions)</AdditionalOptions>
    </Link>
    <PostBuildEvent>
      <Command>"$(RXDK_LIBS)bin\patchSubsystem.exe" -i="$(OutDir)GLSnake.exe" -s=0x000E
"$(RXDK_LIBS)bin\imagebld.exe" /in:"$(OutDir)GLSnake.exe" /out:"$(OutDir)GLSnake.xbe" /nologo /stack:4194304 /debug /nolibwarn /testid:0xBEEF1235 /testname:GLSnake
MKDIR "$(OutDir)Deploy" &gt;NUL 2&gt;&amp;1
COPY /Y "$(OutDir)GLSnake.xbe" "$(OutDir)Deploy\GLSnake.xbe" &gt;NUL
XCOPY /C /Q /I /E /S /Y "$(ProjectDir)data" "$(OutDir)Deploy\data\"</Command>
      <Message>Patching PE, building XBE, staging deploy folder</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <!-- ================================================================
       RELEASE
       ================================================================ -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FavorSizeOrSpeed>Speed</FavorSizeOrSpeed>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <AdditionalIncludeDirectories>$(ProjectDir)xbox;$(ProjectDir);$(ProjectDir)..\RXGL\RXGL;$(VCToolsInstallDir)include;$(WindowsSdkDir)Include\$(WindowsSdkVersion)ucrt;$(XboxSDKDir)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>NDEBUG;_XBOX;WIN32;HAVE_GLUT;HAVE_FTIME;_CRT_SECURE_NO_DEPRECATE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <EnableEnhancedInstructionSet>StreamingSIMDExtensions</EnableEnhancedInstructionSet>
      <ConformanceMode>false</ConformanceMode>
      <ControlFlowGuard>false</ControlFlowGuard>
      <SupportJustMyCode>false</SupportJustMyCode>
      <WarningLevel>Level3</WarningLevel>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <AdditionalOptions>/std:c++17 /EHs-c- /arch:SSE /FI "$(ProjectDir)xbox\preinclude.h" %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <AdditionalDependencies>xapilib.lib;d3d8.lib;d3dx8.lib;xgraphics.lib;xboxkrnl.lib;libcmt.lib</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(XboxSDKDir)lib</AdditionalLibraryDirectories>
      <OutputFile>$(OutDir)GLSnake.exe</OutputFile>
      <GenerateDebugInformation>false</GenerateDebugInformation>
      <SubSystem>Console</SubSystem>
      <StackReserveSize>4194304</StackReserveSize>
      <TargetMachine>MachineX86</TargetMachine>
      <IgnoreAllDefaultLibraries>true</IgnoreAllDefaultLibraries>
      <ImageHasSafeExceptionHandlers>false</ImageHasSafeExceptionHandlers>
      <AdditionalOptions>/ignore:4254 /FORCE:MULTIPLE %(AdditionalOptions)</AdditionalOptions>
    </Link>
    <PostBuildEvent>
      <Command>"$(RXDK_LIBS)bin\patchSubsystem.exe" -i="$(OutDir)GLSnake.exe" -s=0x000E
"$(RXDK_LIBS)bin\imagebld.exe" /in:"$(OutDir)GLSnake.exe" /out:"$(OutDir)GLSnake.xbe" /nologo /stack:4194304 /nolibwarn /testid:0xBEEF1235 /testname:GLSnake
MKDIR "$(OutDir)Deploy" &gt;NUL 2&gt;&amp;1
COPY /Y "$(OutDir)GLSnake.xbe" "$(OutDir)Deploy\GLSnake.xbe" &gt;NUL
XCOPY /C /Q /I /E /S /Y "$(ProjectDir)data" "$(OutDir)Deploy\data\"</Command>
      <Message>Patching PE, building XBE, staging deploy folder</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <!-- ================================================================
       SOURCE FILES
       ================================================================ -->
  <ItemGroup>
    <!-- Xbox platform layer -->
    <ClCompile Include="xbox\main_xbox.cpp" />
    <ClCompile Include="xbox\glut_xbox.cpp" />
    <ClCompile Include="xbox\crt_compat.cpp" />
    <ClCompile Include="xbox\help_screen.cpp" />

    <!-- Game source — compiled as C (avoids void* cast errors; C linkage matches extern "C" in main_xbox.cpp) -->
    <ClCompile Include="glsnake.c" />

    <!-- RXGL shim (OpenGL 1.x to D3D8) — populated via git submodule -->
    <ClCompile Include="..\RXGL\RXGL\rxgl_core.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_renderstate.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_matrix.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_texture.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_lighting.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_immediate.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_arrays.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_displaylist.cpp" />
    <ClCompile Include="..\RXGL\RXGL\rxgl_buffers.cpp" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
</Project>
